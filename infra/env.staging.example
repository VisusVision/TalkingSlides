# VISUS VidLab staging profile.
# Placeholder values only. Put real values in your deployment secret/config system.
# Production fail-fast requirements: DEBUG=False, SECRET_KEY, POSTGRES_HOST,
# MEDIA_TOKEN_SECRET, ALLOWED_HOSTS, CSRF_TRUSTED_ORIGINS, CORS_ALLOWED_ORIGINS.

DJANGO_SETTINGS_MODULE=config.settings
DEBUG=False
SECRET_KEY=replace-with-strong-staging-secret
MEDIA_TOKEN_SECRET=replace-with-strong-staging-media-token-secret

ALLOWED_HOSTS=api.staging.example.com
CSRF_TRUSTED_ORIGINS=https://api.staging.example.com,https://app.staging.example.com
CORS_ALLOWED_ORIGINS=https://app.staging.example.com
CORS_ALLOW_ALL_ORIGINS=False
API_PUBLIC_BASE_URL=https://api.staging.example.com

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

POSTGRES_HOST=staging-postgres.internal
POSTGRES_PORT=5432
POSTGRES_DB=visus_staging
POSTGRES_USER=visus_staging_user
POSTGRES_PASSWORD=replace-with-staging-postgres-password

REDIS_URL=redis://staging-redis.internal:6379/0
CELERY_BROKER_URL=redis://staging-redis.internal:6379/0
CELERY_RESULT_BACKEND=redis://staging-redis.internal:6379/1
CELERY_RENDER_QUEUE=render
CELERY_AVATAR_QUEUE=avatar
CELERY_RENDER_WORKER_CONCURRENCY=1
CELERY_AVATAR_WORKER_CONCURRENCY=1

STORAGE_BACKEND=filesystem
STORAGE_ROOT=/mnt/visus-media
MEDIA_TOKEN_TTL_SECONDS=14400

TTS_SERVICE_URL=http://tts-service.internal:8001
XTTS_ENABLED=1

# Staging validates secure_stream. Keep DRM disabled unless real provider config exists.
LESSON_PROTECTION_DEFAULT_MODE=secure_stream
LESSON_PROTECTION_ALLOW_MP4_FALLBACK=1
LESSON_PROTECTION_FORCE_WATERMARK_FOR_PROTECTED=1
LESSON_PROTECTION_BIND_PLAYBACK_TO_SESSION=1
DRM_ENABLED=0
DRM_STREAMING_ENABLED=1
DRM_HLS_ENCRYPTION_ENABLED=0
DRM_HLS_KEY_ROTATION_SECONDS=0

LECTURE_WATERMARK_ENABLED=1
LECTURE_VISIBILITY_LOCK_ENABLED=1

# Avatar worker is optional in staging and should run separately if enabled.
AVATAR_ENGINE=liveportrait+musetalk
AVATAR_BOOTSTRAP_ON_WORKER_STARTUP=0
AVATAR_GPU_SERIAL_LOCK_ENABLED=1

VITE_API_BASE_URL=https://api.staging.example.com/api/v1
VITE_PLAYER_ENABLE_HLS=true
VITE_PLAYER_ENABLE_DRM_SHAKA=false
VITE_PLAYER_WATERMARK_ENABLED=true
VITE_PLAYER_VISIBILITY_LOCK_ENABLED=true
VITE_PLAYER_HEARTBEAT_ENABLED=true
VITE_PLAYER_HEARTBEAT_INTERVAL_MS=25000
