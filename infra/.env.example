# ============================================================
# AI_ACADEMY – environment variable template
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` to version control.
# ============================================================

# --------------------------
# Django
# --------------------------
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=replace-with-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --------------------------
# PostgreSQL
# --------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=academy_db
POSTGRES_USER=academy_user
POSTGRES_PASSWORD=replace-with-postgres-password

# Constructed DATABASE_URL (used by dj-database-url or similar)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --------------------------
# Redis
# --------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_PREFETCH_MULTIPLIER=1
# Compose runs two Celery worker profiles:
# - worker consumes CELERY_RENDER_QUEUE for non-avatar upload/rerender/transcript jobs.
# - worker-avatar consumes CELERY_AVATAR_QUEUE for avatar/MuseTalk/LivePortrait work.
# Do not increase avatar concurrency unless the target GPU/runtime has been validated.
CELERY_RENDER_QUEUE=render
CELERY_AVATAR_QUEUE=avatar
CELERY_RENDER_WORKER_CONCURRENCY=1
CELERY_AVATAR_WORKER_CONCURRENCY=1
CELERY_WORKER_QUEUES=render
AVATAR_BOOTSTRAP_ON_WORKER_STARTUP=0

# --------------------------
# Local storage
# --------------------------
STORAGE_BACKEND=local
# Docker local development stores runtime media in repo-root ../storage_local
# and mounts it into API, worker, and TTS containers at /app/storage_local.
# The old infra/storage_local path was an accidental compose-relative mount.
# Do not commit runtime media; production should use an external volume or
# a future S3/MinIO storage adapter.
STORAGE_ROOT=/app/storage_local
MEDIA_TOKEN_SECRET=replace-with-media-token-secret
MEDIA_TOKEN_TTL_SECONDS=14400
# Local Docker bind mounts can appear as root-owned inside containers.
# Compose starts app services through a small local entrypoint that chmods only
# the top-level STORAGE_ROOT, then drops back to appuser before running apps.
LOCAL_STORAGE_PERMISSIVE_CHMOD=1
LOCAL_STORAGE_DIR_MODE=0777

# --------------------------
# MinIO (local S3-compatible)
# --------------------------
MINIO_ROOT_USER=replace-with-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-minio-root-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=academy-media
MINIO_USE_SSL=False

# AWS-style env vars (if you use boto3 / django-storages)
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_STORAGE_BUCKET_NAME=${MINIO_BUCKET_NAME}
AWS_S3_ENDPOINT_URL=http://${MINIO_ENDPOINT}

# Google Cloud Storage placeholders. Not active in the current local storage path.
GCS_BUCKET_NAME=replace-with-gcs-bucket-name
GCS_PROJECT_ID=replace-with-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=replace-with-service-account-json-path

# --------------------------
# TTS Service
# --------------------------
TTS_SERVICE_URL=http://tts_service:8001
TTS_PREPROCESSING_ENABLED=true
TTS_MAX_CHARS_PER_CHUNK=500
TTS_TARGET_CHARS_PER_CHUNK=280
TTS_SENTENCE_PAUSE_MS=250
TTS_PARAGRAPH_PAUSE_MS=450
TTS_SLIDE_PAUSE_MS=700
TTS_GLOSSARY_PATH=/app/tts_preprocess/glossary.json
XTTS_ENABLED=1
XTTS_PRELOAD_ON_STARTUP=1
XTTS_WARMUP_BLOCKING=0
# XTTS runtime resilience: retry likely transient model-load/network failures
# before falling through to the existing gTTS and silent fallback chain.
XTTS_LOAD_RECOVERY_ATTEMPTS=2
XTTS_LOAD_RECOVERY_BACKOFF_SEC=2.0
# Do not enable HF_HUB_DISABLE_SSL_VERIFY by default. Prefer a populated local
# model cache; use SSL bypass only as an emergency local/dev workaround.
# Optional Studio-only LLM pronunciation suggestions. Disabled by default.
# Render/rerender/synthesize never depend on these values. Accepted suggestions
# must be saved as normal project TTS overrides before rerender uses them.
TTS_LLM_SUGGESTIONS_ENABLED=false
TTS_LLM_PROVIDER=ollama
# Local host Ollama default for Docker Desktop. If running the API outside
# Docker, localhost may be appropriate instead.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_PRONUNCIATION_MODEL=llama3.1:8b
TTS_LLM_SUGGESTION_TIMEOUT_SECONDS=8
TTS_LLM_MAX_TERMS=20
TTS_LLM_CONTEXT_MAX_CHARS=1000
# Add any API keys for external TTS providers in infra/.env only:
# OPENAI_API_KEY=replace-with-openai-api-key
# ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key

# --------------------------
# Subtitle Translation
# --------------------------
# Enabled by default for owner-triggered subtitle sidecar generation only.
# Rerender does not auto-generate translations.
SUBTITLE_TRANSLATION_ENABLED=true
SUBTITLE_TRANSLATION_PROVIDER=auto
SUBTITLE_TRANSLATION_PROVIDER_CHAIN=api,ollama,libretranslate,argos,mock
SUBTITLE_TRANSLATION_ALLOW_MOCK_FALLBACK=true
SUBTITLE_TRANSLATION_TIMEOUT_SECONDS=20
SUBTITLE_TRANSLATION_TARGET_LANGUAGES=

# Public Watch-page subtitle language requests. Public requests are constrained
# to this allowlist and protected by cache-backed rate limits and generation
# locks. Owner/staff Studio generation remains broader.
SUBTITLE_PUBLIC_REQUESTS_ENABLED=true
SUBTITLE_PUBLIC_REQUEST_LANGUAGE_ALLOWLIST=en,ar,tr,fr,de,es,it,pt,ru,zh,ja,ko,hi,ur,id,fa
SUBTITLE_PUBLIC_REQUEST_RATE_LIMIT_PER_HOUR=10
SUBTITLE_PUBLIC_REQUEST_RATE_LIMIT_ANON_PER_HOUR=5
SUBTITLE_PUBLIC_REQUEST_LOCK_SECONDS=300
SUBTITLE_PUBLIC_REQUEST_MAX_ACTIVE_PER_PROJECT=3
# In DEBUG/dev, mock fallback can be used for demos. In production set this to
# false unless you intentionally want public requests to return fake [lang] text.
# Defaults to true in DEBUG and false when DEBUG=false.
# SUBTITLE_PRODUCTION_ALLOW_MOCK_FALLBACK=false

# Optional future API-provider foundation. Leave these empty unless you have a
# configured provider; paid/external API calls are skipped when any required
# setting is missing. Do not commit real API keys.
SUBTITLE_TRANSLATION_API_PROVIDER=
SUBTITLE_TRANSLATION_API_BASE_URL=
SUBTITLE_TRANSLATION_API_KEY=
SUBTITLE_TRANSLATION_API_MODEL=

# Preferred free/local broad-language provider. Ollama is optional and skipped
# safely when unreachable or when the configured model is not available.
OLLAMA_TRANSLATION_ENABLED=true
# Ollama base URL for subtitle translation. If not set, it defaults to OLLAMA_BASE_URL.
# Use http://host.docker.internal:11434 for Docker Desktop host access.
OLLAMA_TRANSLATION_BASE_URL=http://host.docker.internal:11434
OLLAMA_TRANSLATION_MODEL=qwen2.5:7b-instruct
OLLAMA_TRANSLATION_TIMEOUT_SECONDS=60
OLLAMA_TRANSLATION_MAX_CUES_PER_BATCH=40
OLLAMA_TRANSLATION_MAX_CHARS_PER_BATCH=6000

# Optional self-hosted LibreTranslate fallback. It is skipped/fails safely when
# unreachable, so local development does not require it to be running.
# When running as a compose service with '--profile translation':
# LIBRETRANSLATE_BASE_URL=http://libretranslate:5000
# When running standalone on host (Docker Desktop):
# LIBRETRANSLATE_BASE_URL=http://host.docker.internal:5000
LIBRETRANSLATE_BASE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=

# Optional offline/local Argos Translate fallback. The Python package and
# language packages are optional and loaded lazily.
ARGOS_TRANSLATE_ENABLED=true
ARGOS_TRANSLATE_PACKAGES_DIR=
ARGOS_TRANSLATE_AUTO_INSTALL=false
# Mock fallback is for dev/demo/test visibility only; generated text is marked
# with [language] prefixes and is not a real translation.

# --------------------------
# Avatar Render Engines
# Real engine commands only. Leave empty to disable that engine.
# --------------------------
AVATAR_ENGINE=liveportrait+musetalk
MUSETALK_HOME=/opt/musetalk
MUSETALK_MODEL_PATH=/app/storage_local/models
MUSETALK_ENGINE_VERSION=v1
AVATAR_LIVEPORTRAIT_HOME=/opt/liveportrait
AVATAR_LIVEPORTRAIT_MODEL_PATH=/opt/liveportrait/pretrained_weights
AVATAR_LIVEPORTRAIT_ENTRYPOINT=/opt/liveportrait/inference.py
AVATAR_VIDEO_REFERENCE_CMD=
AVATAR_LIVEPORTRAIT_TIMEOUT_SECONDS=180
AVATAR_LIVEPORTRAIT_IMAGE_DRIVING_TEMPLATE=
AVATAR_LIVEPORTRAIT_CMD=python /app/scripts/liveportrait_runner.py --source_image "{source_image}" --source_video "{source_video}" --audio_path "{audio_path}" --output_path "{output_path}" --fps "{fps}" --target_frame_count "{target_frame_count}" --liveportrait_home "$${AVATAR_LIVEPORTRAIT_HOME}" --liveportrait_entrypoint "$${AVATAR_LIVEPORTRAIT_ENTRYPOINT}" --liveportrait_model_path "$${AVATAR_LIVEPORTRAIT_MODEL_PATH}" --timeout_seconds "$${AVATAR_LIVEPORTRAIT_TIMEOUT_SECONDS}"
AVATAR_STAGE_TIMEOUT_LIVEPORTRAIT_SECONDS=360
AVATAR_STAGE_TIMEOUT_MUSETALK_SECONDS=420
AVATAR_STAGE_TIMEOUT_RESTORATION_SECONDS=180
AVATAR_ORCH_TTS_TIMEOUT_MAX_SECONDS=360
AVATAR_ORCH_LIVEPORTRAIT_TIMEOUT_MAX_SECONDS=900
AVATAR_MUSETALK_TIMEOUT_MAX_SECONDS=7200
AVATAR_MUSETALK_TIMEOUT_SAFETY_MULTIPLIER=1.4
AVATAR_MUSETALK_TIMEOUT_HISTORY_ENABLED=1
AVATAR_MUSETALK_TIMEOUT_LOW_VRAM_MULTIPLIER=1.35
AVATAR_PREVIEW_MUSETALK_TIMEOUT_MAX_SECONDS=1800
AVATAR_ORCH_RESTORATION_TIMEOUT_MAX_SECONDS=900
AVATAR_LOW_VRAM_MUSETALK_TIMEOUT_MULTIPLIER=2.0
MUSETALK_CHUNK_MAX_SECONDS=15
TORCH_HOME=/app/storage_local/models/torch
XDG_CACHE_HOME=/app/storage_local/cache
# MuseTalk routes through the persistent service first. Set standalone fallback
# only for emergency compatibility with the isolated runner path.
AVATAR_MUSETALK_SERVICE_ENABLED=1
AVATAR_MUSETALK_SERVICE_PORT=17860
AVATAR_MUSETALK_STANDALONE_FALLBACK=0
AVATAR_MUSETALK_SERVICE_HTTP_TIMEOUT_MARGIN_SECONDS=60
AVATAR_MUSETALK_ROUTE=service
AVATAR_PREVIEW_FORCE_ISOLATED_MUSETALK=0
AVATAR_LIVEPORTRAIT_ENABLED=1
AVATAR_LIVEPORTRAIT_DRIVER_SOURCE_POLICY=composer_for_image
AVATAR_LP_LOW_MOTION_FALLBACK_TO_STATIC=0
AVATAR_LIVEPORTRAIT_MOTION_PRESET=natural_conservative
AVATAR_LIVEPORTRAIT_ALLOW_BOOSTED_RETRY=0
AVATAR_MIN_EYE_BLINK_CHANGE_COMPOSER=0.0015
AVATAR_PREVIEW_STAGE_TIMEOUT_PREFLIGHT_SECONDS=120
AVATAR_PREVIEW_STAGE_TIMEOUT_TTS_SECONDS=240
AVATAR_PREVIEW_STAGE_TIMEOUT_AUDIO_CONTRACT_SECONDS=120
AVATAR_PREVIEW_STAGE_TIMEOUT_RENDER_SECONDS=780
AVATAR_PREVIEW_LIVEPORTRAIT_MAX_LANDMARK_JITTER=0.018
AVATAR_PREVIEW_LIVEPORTRAIT_EMPIRICAL_PRECHECK=1
AVATAR_PREVIEW_LIVEPORTRAIT_PRECHECK_CANDIDATES=2
AVATAR_PREVIEW_LIVEPORTRAIT_SAFE_RETRY=1
AVATAR_PREVIEW_LIVEPORTRAIT_MOTION_STRENGTH=1.0
AVATAR_PREVIEW_LIVEPORTRAIT_WARP_STRENGTH=0.90
AVATAR_PREVIEW_LIVEPORTRAIT_TEMPORAL_SMOOTHING=0.12
AVATAR_PREVIEW_LIVEPORTRAIT_STABILIZE_WINDOW=9
AVATAR_PREVIEW_LIVEPORTRAIT_STABILIZE_MAX_SHIFT_PX=8
AVATAR_PREVIEW_LIVEPORTRAIT_RETRY_MOTION_STRENGTH=0.66
AVATAR_PREVIEW_LIVEPORTRAIT_RETRY_WARP_STRENGTH=0.78
AVATAR_PREVIEW_LIVEPORTRAIT_RETRY_TEMPORAL_SMOOTHING=0.08
AVATAR_PREVIEW_LIVEPORTRAIT_RETRY_STABILIZE_WINDOW=7
AVATAR_PREVIEW_LIVEPORTRAIT_RETRY_STABILIZE_MAX_SHIFT_PX=6
AVATAR_PREVIEW_PROCESSED_SAFE_SCALE=0.92
AVATAR_PREVIEW_PROCESSED_SAFE_VERTICAL_BIAS=0.56
AVATAR_LIVEPORTRAIT_STABILIZE_ENABLED=1
AVATAR_LIVEPORTRAIT_STABILIZE_WINDOW=11
AVATAR_LIVEPORTRAIT_STABILIZE_MAX_SHIFT_PX=14
AVATAR_LIVEPORTRAIT_STABILIZE_MIN_DETECTION_RATIO=0.65
AVATAR_PREVIEW_TASK_SOFT_TIME_LIMIT_SECONDS=7200
AVATAR_PREVIEW_TASK_HARD_TIME_LIMIT_SECONDS=7500
AVATAR_PREVIEW_TASK_TIME_LIMIT_SAFETY_MARGIN_SECONDS=300
AVATAR_PREVIEW_TASK_HARD_TIME_LIMIT_MARGIN_SECONDS=300
AVATAR_PREVIEW_TASK_TIME_LIMIT_STRICT=1
# Legacy names remain supported; prefer the *_TIME_LIMIT_SECONDS names above.
AVATAR_PREVIEW_TASK_SOFT_TIMEOUT_SECONDS=7200
AVATAR_PREVIEW_TASK_HARD_TIMEOUT_SECONDS=7500
AVATAR_GPU_SERIAL_LOCK_ENABLED=1
AVATAR_GPU_SERIAL_LOCK_PATH=/app/storage_local/avatar_gpu_jobs.lock
AVATAR_LIVEPORTRAIT_MUSETALK_CMD=
AVATAR_MUSETALK_CMD=if [ ! -d "$$MUSETALK_HOME" ]; then echo "Missing MuseTalk home at $$MUSETALK_HOME"; exit 1; fi; if [ ! -d "$$MUSETALK_MODEL_PATH" ]; then echo "Missing MuseTalk model directory at $$MUSETALK_MODEL_PATH"; exit 1; fi; python /app/scripts/musetalk_runner.py --source_image "{source_image}" --source_video "{source_video}" --audio_path "{audio_path}" --output_path "{output_path}"
AVATAR_SADTALKER_CMD=
# AVATAR_WAV2LIP_CHECKPOINT=/app/storage_local/models/wav2lip_gan.pth
# AVATAR_WAV2LIP_CMD=if [ ! -f "$$AVATAR_WAV2LIP_CHECKPOINT" ]; then echo "Missing Wav2Lip checkpoint at $$AVATAR_WAV2LIP_CHECKPOINT"; exit 1; fi; cd /opt/wav2lip; mkdir -p temp; python /opt/wav2lip/inference.py --checkpoint_path "$$AVATAR_WAV2LIP_CHECKPOINT" --face "{source_image}" --audio "{audio_path}" --outfile "{output_path}"

# Example templates (replace with real commands available in your worker image):
# AVATAR_MUSETALK_CMD=python /opt/musetalk/infer.py --source_image "{source_image}" --driven_audio "{audio_path}" --result_path "{output_path}"
# AVATAR_SADTALKER_CMD=python /opt/sadtalker/inference.py --source_image "{source_image}" --driven_audio "{audio_path}" --result_dir /tmp/sadtalker_out ; cp /tmp/sadtalker_out/result.mp4 "{output_path}"
# AVATAR_WAV2LIP_CMD=python /opt/wav2lip/inference.py --face "{source_video}" --audio "{audio_path}" --outfile "{output_path}"
# AVATAR_VIDEO_REFERENCE_CMD=python /opt/avatar_ref/run.py --ref_video "{source_video}" --ref_image "{source_image}" --audio "{audio_path}" --output "{output_path}"

# Composite preview/lesson controls.
AVATAR_PREVIEW_USE_LIVEPORTRAIT=1
AVATAR_PREVIEW_USE_MUSETALK=1
AVATAR_PREVIEW_USE_RESTORATION=0
AVATAR_PREVIEW_RESTORE_CMD=
AVATAR_PREVIEW_RESTORATION_MODEL=codeformer
AVATAR_ENABLE_COMPOSITE_LESSON=0
AVATAR_ALLOW_COMPOSITE_FALLBACK=0

# Composite is default when LivePortrait runtime is installed.
# If startup checks fail for composite runtime, AVATAR_ALLOW_COMPOSITE_FALLBACK=1 allows
# automatic fallback to stable musetalk preview path with explicit warning logs.
# AVATAR_LIVEPORTRAIT_HOME and AVATAR_LIVEPORTRAIT_ENTRYPOINT are code/runtime paths.
# AVATAR_LIVEPORTRAIT_MODEL_PATH is model/data only.
# Keep fallback empty unless explicitly testing a secondary real engine.
AVATAR_REAL_FALLBACK_ENGINE=

# Metadata/debug controls used by strict validation + cache keys.
AVATAR_ENGINE_VERSION=musetalk:v1
AVATAR_SAVE_FAILED_DEBUG=1

# --------------------------
# Frontend
# --------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_PLAYER_ENABLE_HLS=true
VITE_PLAYER_ENABLE_DRM_SHAKA=false
VITE_PLAYER_WATERMARK_ENABLED=true
VITE_PLAYER_VISIBILITY_LOCK_ENABLED=true
VITE_PLAYER_HEARTBEAT_ENABLED=true
VITE_PLAYER_HEARTBEAT_INTERVAL_MS=25000

# --------------------------
# Google Sign-In
# Keep disabled until keys are configured.
# --------------------------
GOOGLE_AUTH_ENABLED=0
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
# Backend callback URL registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/redirect/callback/
# Frontend URL to receive token after backend callback finishes
GOOGLE_REDIRECT_SUCCESS_URL=http://localhost:3000/

# --------------------------
# DRM playback contract
# Only non-secret player initialization values should be exposed by the API.
# Keep provider credentials and signing secrets on the backend or in your DRM vendor.
# IMPORTANT: docker compose services read infra/.env at startup. After changing
# protection values below, restart API and worker containers to apply updates:
#   docker compose -f infra/docker-compose.yml up -d --force-recreate api worker
# --------------------------
DRM_ENABLED=0
DRM_PROVIDER_NAME=external
DRM_PREFERRED_SYSTEM=widevine

# Legacy single-system compatibility values.
DRM_KEY_SYSTEM=
DRM_LICENSE_URL=
DRM_CERTIFICATE_URL=

DRM_ASSET_ID_PREFIX=lesson-
DRM_CONTENT_ID_PREFIX=project-
DRM_PLAYBACK_SESSION_PREFIX=playback

DRM_WIDEVINE_ENABLED=0
DRM_WIDEVINE_KEY_SYSTEM=com.widevine.alpha
DRM_WIDEVINE_LICENSE_URL=
DRM_WIDEVINE_CERTIFICATE_URL=
DRM_WIDEVINE_CONTENT_TYPE=video/mp4

DRM_PLAYREADY_ENABLED=0
DRM_PLAYREADY_KEY_SYSTEM=com.microsoft.playready
DRM_PLAYREADY_LICENSE_URL=
DRM_PLAYREADY_CERTIFICATE_URL=
DRM_PLAYREADY_CONTENT_TYPE=video/mp4

DRM_FAIRPLAY_ENABLED=0
DRM_FAIRPLAY_KEY_SYSTEM=com.apple.fps.1_0
DRM_FAIRPLAY_LICENSE_URL=
DRM_FAIRPLAY_CERTIFICATE_URL=
DRM_FAIRPLAY_CONTENT_TYPE=application/vnd.apple.mpegurl

DRM_STREAMING_ENABLED=0
DRM_HLS_ENCRYPTION_ENABLED=0
DRM_HLS_KEY_ROTATION_SECONDS=0

LESSON_PROTECTION_DEFAULT_MODE=public
# Mode precedence in local/dev:
# - Explicit LESSON_PROTECTION_DEFAULT_MODE=public forces public mode.
# - Existing lesson sidecars are ignored if they conflict with explicit public.
# - secure_stream/drm_protected can still be used explicitly when desired.
LESSON_PROTECTION_ALLOW_MP4_FALLBACK=1
LESSON_PROTECTION_FORCE_WATERMARK_FOR_PROTECTED=0
LESSON_PROTECTION_TOKEN_TTL_PUBLIC_SECONDS=14400
LESSON_PROTECTION_TOKEN_TTL_SECURE_SECONDS=14400
LESSON_PROTECTION_TOKEN_TTL_DRM_SECONDS=600
LESSON_PROTECTION_BIND_PLAYBACK_TO_SESSION=1
LESSON_PROTECTION_REQUIRE_HLS_ENCRYPTION_FOR_DRM=0
LESSON_PROTECTION_REQUIRE_DRM_METADATA_FOR_DRM=1
