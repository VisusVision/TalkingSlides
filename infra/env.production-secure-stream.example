# VISUS VidLab production secure_stream profile.
# Placeholder values only. Put real values in a secret manager or deployment platform.
# Required by production fail-fast guard: DEBUG=False, SECRET_KEY, POSTGRES_HOST,
# MEDIA_TOKEN_SECRET, ALLOWED_HOSTS, CSRF_TRUSTED_ORIGINS, CORS_ALLOWED_ORIGINS.

DJANGO_SETTINGS_MODULE=config.settings
DEBUG=False
SECRET_KEY=replace-with-strong-production-secret
MEDIA_TOKEN_SECRET=replace-with-strong-production-media-token-secret

ALLOWED_HOSTS=api.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOW_ALL_ORIGINS=False
API_PUBLIC_BASE_URL=https://api.example.com

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

POSTGRES_HOST=prod-postgres.internal
POSTGRES_PORT=5432
POSTGRES_DB=visus_prod
POSTGRES_USER=visus_prod_user
POSTGRES_PASSWORD=replace-with-production-postgres-password

REDIS_URL=redis://prod-redis.internal:6379/0
CELERY_BROKER_URL=redis://prod-redis.internal:6379/0
CELERY_RESULT_BACKEND=redis://prod-redis.internal:6379/1
CELERY_RENDER_QUEUE=render
CELERY_AVATAR_QUEUE=avatar
CELERY_RENDER_WORKER_CONCURRENCY=2
CELERY_AVATAR_WORKER_CONCURRENCY=1

STORAGE_BACKEND=local
STORAGE_ROOT=/mnt/visus-media
MEDIA_TOKEN_TTL_SECONDS=14400

TTS_SERVICE_URL=http://tts-service.internal:8001
XTTS_ENABLED=1

LESSON_PROTECTION_DEFAULT_MODE=secure_stream
LESSON_PROTECTION_ALLOW_MP4_FALLBACK=1
LESSON_PROTECTION_FORCE_WATERMARK_FOR_PROTECTED=1
LESSON_PROTECTION_TOKEN_TTL_PUBLIC_SECONDS=14400
LESSON_PROTECTION_TOKEN_TTL_SECURE_SECONDS=14400
LESSON_PROTECTION_BIND_PLAYBACK_TO_SESSION=1
LESSON_PROTECTION_MULTI_TAB_ENFORCEMENT=1

DRM_ENABLED=0
DRM_STREAMING_ENABLED=1
DRM_HLS_ENCRYPTION_ENABLED=1
DRM_HLS_KEY_ROTATION_SECONDS=0

LECTURE_WATERMARK_ENABLED=1
LECTURE_VISIBILITY_LOCK_ENABLED=1

# Avatar requires a separate GPU node/worker when enabled.
AVATAR_ENGINE=liveportrait+musetalk
AVATAR_BOOTSTRAP_ON_WORKER_STARTUP=1
AVATAR_GPU_SERIAL_LOCK_ENABLED=1

VITE_API_BASE_URL=https://api.example.com/api/v1
VITE_PLAYER_ENABLE_HLS=true
VITE_PLAYER_ENABLE_DRM_SHAKA=false
VITE_PLAYER_WATERMARK_ENABLED=true
VITE_PLAYER_VISIBILITY_LOCK_ENABLED=true
VITE_PLAYER_HEARTBEAT_ENABLED=true
VITE_PLAYER_HEARTBEAT_INTERVAL_MS=25000
