# VISUS VidLab local development profile.
# Copy to infra/.env for local work only:
#   Copy-Item infra\env.local.example infra\.env
# Never commit real infra/.env files.

DJANGO_SETTINGS_MODULE=config.settings
DEBUG=True
SECRET_KEY=local-dev-placeholder-secret
MEDIA_TOKEN_SECRET=local-dev-placeholder-media-token-secret

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_ALL_ORIGINS=True
API_PUBLIC_BASE_URL=http://localhost:8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=academy_db
POSTGRES_USER=academy_user
POSTGRES_PASSWORD=replace-with-local-postgres-password

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_RENDER_QUEUE=render
CELERY_AVATAR_QUEUE=avatar
CELERY_RENDER_WORKER_CONCURRENCY=1
CELERY_AVATAR_WORKER_CONCURRENCY=1

STORAGE_BACKEND=local
STORAGE_ROOT=/app/storage_local
LOCAL_STORAGE_PERMISSIVE_CHMOD=1
LOCAL_STORAGE_DIR_MODE=0777

TTS_SERVICE_URL=http://tts_service:8001
XTTS_ENABLED=1
XTTS_PRELOAD_ON_STARTUP=1
XTTS_WARMUP_BLOCKING=0

# Avatar is optional in local dev. Start worker-avatar only after GPU/runtime validation.
AVATAR_ENGINE=liveportrait+musetalk
AVATAR_BOOTSTRAP_ON_WORKER_STARTUP=0
AVATAR_GPU_SERIAL_LOCK_ENABLED=1

# Local playback defaults: simple public playback. secure_stream can be tested by changing this value.
LESSON_PROTECTION_DEFAULT_MODE=public
LESSON_PROTECTION_ALLOW_MP4_FALLBACK=1
LESSON_PROTECTION_BIND_PLAYBACK_TO_SESSION=1
LECTURE_WATERMARK_ENABLED=1
LECTURE_VISIBILITY_LOCK_ENABLED=1

DRM_ENABLED=0
DRM_STREAMING_ENABLED=0
DRM_HLS_ENCRYPTION_ENABLED=0

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_PLAYER_ENABLE_HLS=true
VITE_PLAYER_ENABLE_DRM_SHAKA=false
VITE_PLAYER_WATERMARK_ENABLED=true
VITE_PLAYER_VISIBILITY_LOCK_ENABLED=true
VITE_PLAYER_HEARTBEAT_ENABLED=true
VITE_PLAYER_HEARTBEAT_INTERVAL_MS=25000
