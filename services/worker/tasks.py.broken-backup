logger = logging.getLogger(__name__)

# Storage root for worker output (under the shared volume)
STORAGE_ROOT = os.environ.get("STORAGE_ROOT", "storage_local/output")

# Base URL served by Django's MediaServeView at /api/v1/media/<path>.
