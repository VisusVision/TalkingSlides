                "avatar_preview_video",
                "avatar_last_preview_path",
                "avatar_last_preview_status",
                "avatar_last_preview_job_id",
                "avatar_image_status",
                "avatar_preview_error",
                "updated_at",
            ]
        )

        if job_id:
            Job.objects.filter(id=int(job_id)).update(
                status="done",
                progress=100,
                result_url=rel_preview,
