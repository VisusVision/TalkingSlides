"""
services/worker/tasks.py
=========================
Celery task definitions for AI_ACADEMY worker.

Parallel pipeline
-----------------
process_pptx_to_video   (entry-point, same send_task name as before)
  └─ export_project      (step 1 — extracts slide images + notes, runs inline)
  └─ chord(
       group([synthesize_and_render_slide, ...]),   # step 2 — parallel per-slide
       concat_and_finalize                           # step 3 — joins parts, updates DB
     )

Smoke-test tasks: ping, tts_render
"""

