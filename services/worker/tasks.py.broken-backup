@worker_ready.connect
def _log_avatar_engine_startup_status(sender=None, **kwargs):
    def _fatal_startup(msg: str) -> None:
        logger.critical(msg)
        os._exit(70)

    try:
        backend_versions: dict[str, str] = {}
        expected_versions = {
            "python": "3.10",
            "torch": "2.0.1",
            "torchvision": "0.15.2",
            "torchaudio": "2.0.2",
            "mmcv": "2.0.1",
            else source_image_processed_abs
        )
        source_video_abs = ""
        if profile.avatar_video_processed or profile.avatar_video_original:
            source_video_abs = str(Path(storage_root) / (profile.avatar_video_processed or profile.avatar_video_original))

        if not source_image_processed_abs and not source_video_abs:
            raise RuntimeError("Teacher avatar preview has no usable image or video source.")

        profile_engine = _normalize_avatar_engine(profile.avatar_lipsync_engine or profile.avatar_engine_primary or os.environ.get("AVATAR_ENGINE"))
        preview_engine = profile_engine
        liveportrait_requested = bool(preview_engine == "liveportrait+musetalk")

        use_processed_focus_crop = str(os.environ.get("AVATAR_PREVIEW_USE_PROCESSED_FOCUS_CROP", "0")).strip().lower() in {
            "1",
            "true",
            "yes",
            "on",
        }

        _stage_log(
            event="stage_started",
            stage="preflight_selection",
            input_path=(source_image_original_abs or source_video_abs),
            output_path=str(preview_reference_path),
        )
        current_stage = "preflight_selection"
        current_stage_input = str(source_image_original_abs or source_video_abs)
        current_stage_output = str(preview_reference_path)
        current_stage_started_at = time.monotonic()
        preflight_started_at = time.monotonic()

        preview_source_candidates: list[dict[str, Any]] = []
        source_build_warnings: list[str] = []
        preview_reference_meta: dict[str, Any] = {}

        def _append_candidate(
            *,
            source_key: str,
            source_label: str,
            source_image_path: str,
            avatar_reference_type: str,
            source_video_path: str,
            reference_meta: dict[str, Any],
        ) -> None:
            preview_source_candidates.append(
                {
                    "source_key": source_key,
                    "source_label": source_label,
                    "source_image_path": source_image_path,
                    "avatar_reference_type": avatar_reference_type,
                    "source_video_path": source_video_path,
                    "reference_meta": reference_meta,
                    "preflight_score": float(reference_meta.get("preflight_score") or 0.0),
                }
            )

        if source_image_original_abs and Path(source_image_original_abs).exists():
            preview_image_path = preview_dir / "preview_reference_image.png"
            try:
                image_meta = build_preview_reference_image(
                    original_image_path=source_image_original_abs,
                    output_path=str(preview_image_path),
                )
                _append_candidate(
                    source_key="image_original_preflight",
                    source_label="image",
                    source_image_path=str(preview_image_path),
                    avatar_reference_type="image",
                    source_video_path="",
                    reference_meta=image_meta,
                )
            except Exception as preview_ref_exc:
                source_build_warnings.append(str(preview_ref_exc))
                logger.warning(
                    "Avatar preview image preflight rejected teacher=%s source=%s reason=%s",
                    teacher_id,
                    source_image_original_abs,
                    preview_ref_exc,
                )

        if source_video_abs and Path(source_video_abs).exists():
            preview_video_path = preview_dir / "preview_reference_video.png"
            try:
                video_meta = build_preview_video_reference_image(
                    source_video_path=source_video_abs,
                    output_path=str(preview_video_path),
                )
                _append_candidate(
                    source_key="video_preflight",
                    source_label="video",
                    source_image_path=str(preview_video_path),
                    avatar_reference_type="video",
                    source_video_path=source_video_abs,
                    reference_meta=video_meta,
                )
            except Exception as video_ref_exc:
                source_build_warnings.append(str(video_ref_exc))
                logger.warning(
                    "Avatar preview video preflight rejected teacher=%s source=%s reason=%s",
                    teacher_id,
                    source_video_abs,
                    video_ref_exc,
                )

        if use_processed_focus_crop and source_image_processed_abs and Path(source_image_processed_abs).exists():
            preview_focus_path = preview_dir / "preview_reference_focus.png"
            try:
                focus_meta = build_preview_focus_reference_image(
                    processed_image_path=source_image_processed_abs,
                    output_path=str(preview_focus_path),
                )
                _append_candidate(
                    source_key="image_processed_focus",
                    source_label="image",
                    source_image_path=str(preview_focus_path),
                    avatar_reference_type="image",
                    source_video_path="",
                    reference_meta=focus_meta,
                )
            except Exception as focus_exc:
                source_build_warnings.append(str(focus_exc))
                logger.warning(
                    "Avatar preview processed focus preflight rejected teacher=%s source=%s reason=%s",
                    teacher_id,
                    source_image_processed_abs,
                    focus_exc,
                )

        if not preview_source_candidates and source_image_processed_abs and Path(source_image_processed_abs).exists():
            # Conservative fallback from processed identity image with added headroom.
            preview_fallback_path = preview_dir / "preview_reference_fallback.png"
            try:
                fallback_meta = build_preview_processed_safe_reference_image(
                    processed_image_path=source_image_processed_abs,
                    output_path=str(preview_fallback_path),
                    scale=0.90,
                    vertical_bias=0.58,
                )
                _append_candidate(
                    source_key="image_processed_safe_headroom",
                    source_label="image",
                    source_image_path=str(preview_fallback_path),
                    avatar_reference_type="image",
                    source_video_path="",
                    reference_meta=fallback_meta,
                )
            except Exception as fallback_exc:
                source_build_warnings.append(str(fallback_exc))

        if source_image_processed_abs and Path(source_image_processed_abs).exists():
            # Slightly tighter LP-safe variant to improve landmark stability on some faces.
            preview_fallback_tight_path = preview_dir / "preview_reference_fallback_tight.png"
            try:
                fallback_tight_meta = build_preview_processed_safe_reference_image(
                    processed_image_path=source_image_processed_abs,
                    output_path=str(preview_fallback_tight_path),
                    scale=0.94,
                    vertical_bias=0.55,
                )
                _append_candidate(
                    source_key="image_processed_safe_balanced",
                    source_label="image",
                    source_image_path=str(preview_fallback_tight_path),
                    avatar_reference_type="image",
                    source_video_path="",
                    reference_meta=fallback_tight_meta,
                )
            except Exception as fallback_tight_exc:
                source_build_warnings.append(str(fallback_tight_exc))

        if not preview_source_candidates and source_image_processed_abs and Path(source_image_processed_abs).exists():
            # Final fallback keeps legacy behavior for compatibility.
            preview_focus_fallback_path = preview_dir / "preview_reference_focus_fallback.png"
            try:
                fallback_focus_meta = build_preview_focus_reference_image(
                    processed_image_path=source_image_processed_abs,
                    output_path=str(preview_focus_fallback_path),
                )
                _append_candidate(
                    source_key="image_processed_focus_fallback",
                    source_label="image",
                    source_image_path=str(preview_focus_fallback_path),
                    avatar_reference_type="image",
                    source_video_path="",
                    reference_meta=fallback_focus_meta,
                )
            except Exception as fallback_focus_exc:
                source_build_warnings.append(str(fallback_focus_exc))

        if not preview_source_candidates:
            # Soft precheck behavior for preview: keep readable media in play and let strict final validation decide.
            if source_image_original_abs and Path(source_image_original_abs).exists() and Path(source_image_original_abs).stat().st_size > 0:
                _append_candidate(
                    source_key="image_original_soft_fallback",
                    source_label="image",
                    source_image_path=str(source_image_original_abs),
                    avatar_reference_type="image",
                    source_video_path="",
                    reference_meta={
                        "preflight_score": 0.01,
                        "soft_precheck_fallback": True,
                        "fallback_reason": "readable_source_with_precheck_rejection",
                    },
                )
            elif source_image_processed_abs and Path(source_image_processed_abs).exists() and Path(source_image_processed_abs).stat().st_size > 0:
                _append_candidate(
                    source_key="image_processed_soft_fallback",
                    source_label="image",
                    source_image_path=str(source_image_processed_abs),
                    avatar_reference_type="image",
                    source_video_path="",
                    reference_meta={
                        "preflight_score": 0.01,
                        "soft_precheck_fallback": True,
                        "fallback_reason": "readable_processed_source_with_precheck_rejection",
                    },
                )
            if preview_source_candidates:
                logger.warning(
                    "Avatar preview soft precheck fallback teacher=%s selected=%s warnings=%s",
                    teacher_id,
                    str(preview_source_candidates[0].get("source_key") or ""),
                    source_build_warnings,
                )
            else:
                joined = " | ".join(source_build_warnings) if source_build_warnings else "no preflight source available"
                raise RuntimeError(
                    "Avatar preview preflight rejected all sources before inference. "
                    f"details={joined}. Re-upload avatar with full headroom and less torso."
                )

        preflight_elapsed = time.monotonic() - preflight_started_at
        _stage_log(
            event="stage_finished",
            stage="preflight_selection",
            input_path=(source_image_original_abs or source_video_abs),
            output_path=str(preview_reference_path),
            elapsed_seconds=preflight_elapsed,
            details="success",
        )
        current_stage = ""
        if preflight_elapsed > stage_preflight_timeout:
            raise RuntimeError(f"preflight_timeout:exceeded_{int(stage_preflight_timeout)}s")

        def _history_metrics_for_source(source_image_path: str) -> dict[str, Any]:
            debug_root = preview_dir / "debug_failed"
            if not debug_root.exists():
                return {}
            best_score = float("-inf")
            best: dict[str, Any] = {}
            for entry in sorted(debug_root.iterdir(), reverse=True):
                report_path = entry / "validation_report.json"
                if not report_path.exists():
                    continue
                try:
                    report = json.loads(report_path.read_text(encoding="utf-8"))
                except Exception:
                    continue
                req = report.get("request") or {}
                if str(req.get("source_image_path") or "") != source_image_path:
                    continue
                metrics = report.get("metrics") or {}
                quality = metrics.get("quality_checks") or {}
                lip = float(quality.get("lip_movement_score") or 0.0)
                mouth = float(quality.get("mouth_openness_change") or 0.0)
                lip_component = min(lip / 12.0, 1.0)
                mouth_component = min(mouth / 0.01, 1.0)
                quality_rank = (lip_component * 6.0) + (mouth_component * 4.0)
                if quality_rank > best_score:
                    best_score = quality_rank
                    best = {
                        "history_lip_movement_score": lip,
                        "history_mouth_openness_change": mouth,
                        "history_quality_rank": round(quality_rank, 6),
                        "history_debug_path": str(report.get("debug_path") or ""),
                    }
            return best

        strict_lp_jitter = float(os.environ.get("AVATAR_PREVIEW_LIVEPORTRAIT_MAX_LANDMARK_JITTER", "0.018") or 0.018)
        preview_lp_jitter_margin = float(os.environ.get("AVATAR_PREVIEW_LIVEPORTRAIT_PRECHECK_JITTER_MARGIN", "0.004") or 0.004)
        preview_lp_jitter_max = strict_lp_jitter + max(0.0, preview_lp_jitter_margin)
        preview_lp_recovery_extra_margin = float(
            os.environ.get("AVATAR_PREVIEW_LIVEPORTRAIT_PRECHECK_RECOVERY_EXTRA_MARGIN", "0.003") or 0.003
        )
        rejected_lp_candidates: list[dict[str, Any]] = []

        for candidate in preview_source_candidates:
            source_path = str(candidate.get("source_image_path") or "")
            source_path_obj = Path(source_path) if source_path else None
            source_exists = bool(source_path_obj and source_path_obj.exists() and source_path_obj.is_file() and source_path_obj.stat().st_size > 0)
            history = _history_metrics_for_source(source_path)
            candidate.update(history)
            crop_metrics = (candidate.get("reference_meta") or {}).get("crop_metrics") or {}
            landmark_stability = (candidate.get("reference_meta") or {}).get("landmark_stability") or {}
            landmark_jitter_estimate = float(landmark_stability.get("landmark_jitter_estimate") or 0.2)
            landmark_detection_success_ratio = float(landmark_stability.get("landmark_detection_success_ratio") or 0.0)
            source_face_detectable = landmark_detection_success_ratio > 0.01
            centering_score = max(
                0.0,
                1.0 - min(1.0, float(crop_metrics.get("center_offset_x_ratio") or 0.0) / 0.12),
            )
            centering_score *= max(
                0.0,
                1.0 - min(1.0, float(crop_metrics.get("center_offset_y_ratio") or 0.0) / 0.15),
            )
            headroom_score = max(0.0, min(1.0, float(crop_metrics.get("top_margin_ratio") or 0.0) / 0.70))
            mouth_pos = float(crop_metrics.get("mouth_position_ratio") or 0.0)
            mouth_position_score = max(0.0, 1.0 - min(1.0, abs(mouth_pos - 0.64) / 0.24))
            face_area_ratio = float(crop_metrics.get("face_area_ratio_in_crop") or 0.0)
            target_face_area = 0.24
            face_size_score = max(0.0, 1.0 - min(1.0, abs(face_area_ratio - target_face_area) / 0.16))
            landmark_stability_score = max(0.0, 1.0 - min(1.0, landmark_jitter_estimate / max(strict_lp_jitter, 1e-6)))
            candidate["face_centering_score"] = round(float(centering_score), 6)
            candidate["forehead_headroom_score"] = round(float(headroom_score), 6)
            candidate["mouth_position_score"] = round(float(mouth_position_score), 6)
            candidate["face_size_score"] = round(float(face_size_score), 6)
            candidate["landmark_jitter_estimate"] = round(float(landmark_jitter_estimate), 6)
            candidate["landmark_detection_success_ratio"] = round(float(landmark_detection_success_ratio), 6)
            candidate["landmark_stability_score"] = round(float(landmark_stability_score), 6)
            candidate["source_exists"] = bool(source_exists)
            candidate["source_face_detectable"] = bool(source_face_detectable)
            # Preview precheck should only hard-reject unreadable inputs.
            # Face rejection is enforced by canonical detector right before engine handoff.
            candidate["precheck_hard_invalid"] = bool(not source_exists)
            if not source_exists:
                candidate["precheck_hard_invalid_reason"] = "missing_or_unreadable_source"
            elif not source_face_detectable:
                candidate["precheck_hard_invalid_reason"] = "face_detection_borderline"
            else:
                candidate["precheck_hard_invalid_reason"] = ""
            preflight_score = float(candidate.get("preflight_score") or 0.0)
            history_quality = float(candidate.get("history_quality_rank") or float("nan"))

            if liveportrait_requested:
                history_component = 0.0 if math.isnan(history_quality) else (history_quality * 8.0)
                ranking_score = (
                    (landmark_stability_score * 500.0)
                    + (face_size_score * 120.0)
                    + (headroom_score * 90.0)
                    + (float(centering_score) * 80.0)
                    + (mouth_position_score * 70.0)
                    + (preflight_score * 20.0)
                    + history_component
                )
                ranking_reason = "landmark_stability_weighted"
            else:
                if math.isnan(history_quality):
                    ranking_score = preflight_score
                    ranking_reason = "preflight_only"
                else:
                    ranking_score = (history_quality * 100.0) + preflight_score
                    ranking_reason = "history_lip_mouth_plus_preflight"

            if liveportrait_requested and landmark_jitter_estimate > preview_lp_jitter_max:
                candidate["liveportrait_precheck_passed"] = False
                candidate["liveportrait_precheck_reason"] = (
                    f"landmark_jitter_estimate={landmark_jitter_estimate:.6f}>max={preview_lp_jitter_max:.6f}"
                )
                rejected_lp_candidates.append(
                    {
                        "source_key": candidate.get("source_key"),
                        "landmark_jitter_estimate": round(float(landmark_jitter_estimate), 6),
                        "max_allowed": round(float(preview_lp_jitter_max), 6),
                        "precheck_reason": candidate.get("liveportrait_precheck_reason"),
                    }
                )
            else:
                candidate["liveportrait_precheck_passed"] = True
                candidate["liveportrait_precheck_reason"] = ""
            candidate["liveportrait_precheck_threshold"] = round(float(preview_lp_jitter_max), 6)

            candidate["ranking_score"] = round(ranking_score, 6)
            candidate["ranking_reason"] = ranking_reason

        preview_source_candidates.sort(key=lambda item: float(item.get("ranking_score") or 0.0), reverse=True)
        ranked_valid_candidates = [c for c in preview_source_candidates if not bool(c.get("precheck_hard_invalid"))]
        if not ranked_valid_candidates:
            invalid_summary = [
                {
                    "source_key": c.get("source_key"),
                    "reason": c.get("precheck_hard_invalid_reason"),
                }
                for c in preview_source_candidates
            ]
            raise RuntimeError(
                "liveportrait_precheck_failed:no_usable_source "
                f"reasons={invalid_summary}"
            )
        for idx, item in enumerate(preview_source_candidates, start=1):
            item["expected_stability_rank"] = int(idx)
        selected_source = dict(ranked_valid_candidates[0])
        precheck_recovery_used = False
        precheck_recovery_details: dict[str, Any] = {}
        best_effort_preview_warning = ""
        preview_reference_meta = dict(selected_source.get("reference_meta") or {})
        preview_reference_meta["source_key"] = str(selected_source.get("source_key") or "")
        preview_reference_meta["source_label"] = str(selected_source.get("source_label") or "")
        runner_up = dict(preview_source_candidates[1]) if len(preview_source_candidates) > 1 else None

        if liveportrait_requested:
            selected_jitter = float(selected_source.get("landmark_jitter_estimate") or 0.2)
            precheck_decision = "strict_pass"
            if selected_jitter > strict_lp_jitter and selected_jitter <= preview_lp_jitter_max:
                precheck_decision = "preview_margin_warn"

            if selected_jitter > preview_lp_jitter_max:
                overrun = selected_jitter - preview_lp_jitter_max
                near_miss = overrun <= max(0.0, preview_lp_recovery_extra_margin)
                recovery_possible = bool(source_image_processed_abs and Path(source_image_processed_abs).exists())
                if near_miss and recovery_possible:
                    recovery_output = preview_dir / f"preview_reference_recovery_{str(selected_source.get('source_key') or 'selected')}.png"
                    selected_crop_candidate = (selected_source.get("reference_meta") or {}).get("crop_candidate") or {}
                    base_scale = float(selected_crop_candidate.get("scale") or 0.94)
                    base_vertical_bias = float(selected_crop_candidate.get("vertical_bias") or 0.55)
                    recovery_scale = max(0.82, min(0.95, base_scale - 0.05))
                    recovery_vertical_bias = max(0.46, min(0.62, base_vertical_bias - 0.03))
                    recovery_meta = build_preview_processed_safe_reference_image(
                        processed_image_path=source_image_processed_abs,
                        output_path=str(recovery_output),
                        scale=recovery_scale,
                        vertical_bias=recovery_vertical_bias,
                    )
                    recovery_landmark = (recovery_meta.get("landmark_stability") or {})
                    recovery_jitter = float(recovery_landmark.get("landmark_jitter_estimate") or 0.2)
                    precheck_recovery_used = True
                    precheck_recovery_details = {
                        "used": True,
                        "reason": "selected_source_near_miss_jitter",
                        "before_jitter": round(selected_jitter, 6),
                        "after_jitter": round(recovery_jitter, 6),
                        "strict_threshold": round(strict_lp_jitter, 6),
                        "preview_threshold": round(preview_lp_jitter_max, 6),
                        "recovery_scale": round(recovery_scale, 6),
                        "recovery_vertical_bias": round(recovery_vertical_bias, 6),
                        "output_path": str(recovery_output),
                    }
                    selected_source["source_image_path"] = str(recovery_output)
                    selected_source["source_key"] = f"{str(selected_source.get('source_key') or 'selected')}_recovery"
                    selected_source["reference_meta"] = dict(recovery_meta)
                    selected_source["landmark_jitter_estimate"] = round(recovery_jitter, 6)
                    precheck_decision = "recovery_warn"
                else:
                    precheck_decision = "high_jitter_warn"
                    precheck_recovery_details = {
                        "used": False,
                        "reason": "recovery_not_applicable",
                        "near_miss": bool(near_miss),
                        "recovery_possible": bool(recovery_possible),
                        "before_jitter": round(selected_jitter, 6),
                        "preview_threshold": round(preview_lp_jitter_max, 6),
                    }

            if precheck_decision != "strict_pass":
                selected_jitter_after = round(float(selected_source.get("landmark_jitter_estimate") or selected_jitter), 6)
                best_effort_preview_warning = (
                    "preview_warning: Using best available avatar source in preview mode; "
                    f"precheck_decision={precheck_decision}; jitter={selected_jitter_after}; "
                    f"strict_threshold={round(strict_lp_jitter, 6)}; preview_threshold={round(preview_lp_jitter_max, 6)}"
                )
                logger.warning(
                    "Avatar preview best-effort precheck warning teacher=%s source=%s warning=%s",
                    teacher_id,
                    selected_source.get("source_key"),
                    best_effort_preview_warning,
                )

            logger.info(
                "Avatar preview liveportrait precheck decision teacher=%s source=%s jitter=%s strict_threshold=%s preview_threshold=%s recovery_used=%s decision=%s",
                teacher_id,
                selected_source.get("source_key"),
                round(float(selected_source.get("landmark_jitter_estimate") or selected_jitter), 6),
                round(strict_lp_jitter, 6),
                round(preview_lp_jitter_max, 6),
                bool(precheck_recovery_used),
                precheck_decision,
            )
            if precheck_recovery_details:
                logger.info(
                    "Avatar preview liveportrait precheck recovery teacher=%s details=%s",
                    teacher_id,
                    precheck_recovery_details,
                )

            preview_reference_meta = dict(selected_source.get("reference_meta") or preview_reference_meta)
            preview_reference_meta["source_key"] = str(selected_source.get("source_key") or "")
            preview_reference_meta["source_label"] = str(selected_source.get("source_label") or "")

            # Canonical engine-aware normalization now runs in avatar.pipeline for both preview and lesson.
            _write_stage_diagnostic(
                stage="liveportrait_input_normalization",
                payload={
                    "enabled": False,
                    "reason": "delegated_to_canonical_input_pipeline",
                    "source_key": selected_source.get("source_key"),
                    "source_label": selected_source.get("source_label"),
                },
            )

        winner_reason_tokens = [
            f"ranking_reason={selected_source.get('ranking_reason')}",
            f"ranking_score={selected_source.get('ranking_score')}",
            f"lip_history={selected_source.get('history_lip_movement_score')}",
            f"mouth_history={selected_source.get('history_mouth_openness_change')}",
            f"mouth_position_score={selected_source.get('mouth_position_score')}",
            f"headroom_score={selected_source.get('forehead_headroom_score')}",
            f"centering_score={selected_source.get('face_centering_score')}",
            f"face_size_score={selected_source.get('face_size_score')}",
            f"landmark_jitter_estimate={selected_source.get('landmark_jitter_estimate')}",
            f"expected_stability_rank={selected_source.get('expected_stability_rank')}",
        ]
        if runner_up:
            winner_reason_tokens.append(
                f"runner_up={runner_up.get('source_key')}"
                f"(rank={runner_up.get('ranking_score')},lip={runner_up.get('history_lip_movement_score')},mouth={runner_up.get('history_mouth_openness_change')})"
            )
        selected_source_reason = "; ".join(winner_reason_tokens)

        logger.info(
            "Avatar preview selected source teacher=%s source_key=%s source_label=%s ranking_reason=%s ranking_score=%s preflight_score=%s history_lip=%s history_mouth_open=%s candidates=%s",
            teacher_id,
            selected_source.get("source_key"),
            selected_source.get("source_label"),
            selected_source.get("ranking_reason"),
            selected_source.get("ranking_score"),
            selected_source.get("preflight_score"),
            selected_source.get("history_lip_movement_score"),
            selected_source.get("history_mouth_openness_change"),
            [
                {
                    "source_key": item.get("source_key"),
                    "ranking_score": item.get("ranking_score"),
                    "preflight_score": item.get("preflight_score"),
                    "history_quality_rank": item.get("history_quality_rank"),
                }
                for item in preview_source_candidates
            ],
        )
        logger.info(
            "Avatar preview source winner_vs_runner_up teacher=%s reason=%s",
            teacher_id,
            selected_source_reason,
        )
        logger.info(
            "Avatar preview liveportrait precheck teacher=%s max_jitter=%s rejected=%s",
            teacher_id,
            preview_lp_jitter_max,
            rejected_lp_candidates,
        )
        _write_stage_diagnostic(
            stage="source_selection",
            payload={
                "selected_source": {
                    "source_key": selected_source.get("source_key"),
                    "source_label": selected_source.get("source_label"),
                    "reason": selected_source_reason,
                    "preflight_score": selected_source.get("preflight_score"),
                    "ranking_score": selected_source.get("ranking_score"),
                    "expected_stability_rank": selected_source.get("expected_stability_rank"),
                    "landmark_jitter_estimate": selected_source.get("landmark_jitter_estimate"),
                    "liveportrait_precheck_passed": selected_source.get("liveportrait_precheck_passed"),
                    "crop_metadata": (selected_source.get("reference_meta") or {}).get("crop_metrics") or {},
                },
                "runner_up": {
                    "source_key": (runner_up or {}).get("source_key"),
                    "ranking_score": (runner_up or {}).get("ranking_score"),
                },
                "liveportrait_precheck": {
                    "enabled": bool(liveportrait_requested),
                    "strict_landmark_jitter": round(float(strict_lp_jitter), 6),
                    "max_landmark_jitter": round(float(preview_lp_jitter_max), 6),
                    "recovery_extra_margin": round(float(preview_lp_recovery_extra_margin), 6),
                    "recovery_used": bool(precheck_recovery_used),
                    "recovery": dict(precheck_recovery_details),
                    "best_effort_warning": str(best_effort_preview_warning or ""),
                    "rejected_sources": rejected_lp_candidates,
                },
                "candidates": preview_source_candidates,
            },
        )

        preview_text_hash = hashlib.sha256(preview_script.encode("utf-8")).hexdigest()
        preview_voice_hash = hashlib.sha256(str(voice_profile.voice_id).encode("utf-8")).hexdigest()[:12]
        cached_source_tts_path = preview_dir / f"preview_source_{preview_voice_hash}_{preview_text_hash[:16]}.mp3"
        source_tts_path.unlink(missing_ok=True)
        audio_path.unlink(missing_ok=True)
        tts_meta: dict[str, Any] = {}
        tts_provider = "cache"
        preview_audio_cache_hit = False
        _stage_log(
            event="stage_started",
            stage="tts_generation",
            input_path=f"voice:{voice_profile.voice_id}",
            output_path=str(source_tts_path),
        )
        current_stage = "tts_generation"
        current_stage_input = f"voice:{voice_profile.voice_id}"
        current_stage_output = str(source_tts_path)
        current_stage_started_at = time.monotonic()
        tts_started_at = time.monotonic()
        if cached_source_tts_path.exists() and cached_source_tts_path.stat().st_size > 0:
            shutil.copy2(cached_source_tts_path, source_tts_path)
            try:
                generated_duration = _verify_preview_audio_or_raise(source_tts_path, tts_duration=None)
                preview_audio_cache_hit = True
                tts_meta = {
                    "provider": "cache",
                    "duration": generated_duration,
                }
            except Exception:
                source_tts_path.unlink(missing_ok=True)
                cached_source_tts_path.unlink(missing_ok=True)

        if not preview_audio_cache_hit:
            tts_meta = _run_tts_with_timeout()
            tts_provider = str(tts_meta.get("provider") or "").strip().lower()
            if tts_provider == "fallback":
                raise RuntimeError("tts_audio_invalid:fallback_audio")

            generated_duration = _verify_preview_audio_or_raise(
                source_tts_path,
                tts_duration=(float(tts_meta["duration"]) if tts_meta.get("duration") is not None else None),
            )
            _trim_preview_audio_silence(source_tts_path)
            generated_duration = _verify_preview_audio_or_raise(source_tts_path, tts_duration=None)
            shutil.copy2(source_tts_path, cached_source_tts_path)

        _stage_log(
            event="stage_finished",
            stage="tts_generation",
            input_path=f"voice:{voice_profile.voice_id}",
            output_path=str(source_tts_path),
            elapsed_seconds=(time.monotonic() - tts_started_at),
            details=("cache_hit" if preview_audio_cache_hit else "generated"),
        )
        _write_stage_diagnostic(
            stage="tts",
            payload={
                "provider": tts_provider,
                "cache_hit": bool(preview_audio_cache_hit),
                "output_path": str(source_tts_path),
                "duration_seconds": round(float(generated_duration), 4),
                "meta": dict(tts_meta or {}),
            },
        )
        current_stage = ""

        if job_id:
            Job.objects.filter(id=int(job_id)).update(
                status="running",
                progress=38,
                error_message=(best_effort_preview_warning if best_effort_preview_warning else ""),
            )
        profile.avatar_last_preview_status = "tts_ready"
        profile.avatar_image_status = "processing"
        profile.avatar_preview_error = ""
        profile.avatar_last_preview_job_id = str(job_id or self.request.id or "")
        profile.save(update_fields=["avatar_last_preview_status", "avatar_image_status", "avatar_preview_error", "avatar_last_preview_job_id", "updated_at"])

        tts_provider = str(tts_meta.get("provider") or tts_provider or "cache").strip().lower()
        _stage_log(
            event="stage_started",
            stage="audio_contract",
            input_path=str(source_tts_path),
            output_path=str(audio_path),
        )
        current_stage = "audio_contract"
        current_stage_input = str(source_tts_path)
        current_stage_output = str(audio_path)
        current_stage_started_at = time.monotonic()
        audio_contract_started_at = time.monotonic()
        duration_contract = _build_preview_audio_contract(source_tts_path, target=audio_path, fps=preview_fps)
        if (time.monotonic() - audio_contract_started_at) > stage_audio_contract_timeout:
            raise RuntimeError(f"stage_stalled:audio_contract>{int(stage_audio_contract_timeout)}s")
        contract_duration = _verify_preview_audio_or_raise(audio_path, tts_duration=None)
        _stage_log(
            event="stage_finished",
            stage="audio_contract",
            input_path=str(source_tts_path),
            output_path=str(audio_path),
            elapsed_seconds=(time.monotonic() - audio_contract_started_at),
            details="success",
        )
        _write_stage_diagnostic(
            stage="audio_contract",
            payload={
                "input_path": str(source_tts_path),
                "output_path": str(audio_path),
                "contract": duration_contract,
                "duration_seconds": round(float(contract_duration), 4),
            },
        )
        current_stage = ""
        if not audio_path.exists() or audio_path.stat().st_size <= 0:
            raise RuntimeError("preview_audio_missing")

        if liveportrait_requested:
            empirical_enabled = str(os.environ.get("AVATAR_PREVIEW_LIVEPORTRAIT_EMPIRICAL_PRECHECK", "1")).strip().lower() in {
                "1",
                "true",
                "yes",
                "on",
            }
            if empirical_enabled:
                ranked_candidates = [dict(selected_source)]
                empirical_results = [
                    _run_liveportrait_empirical_precheck(candidate=candidate, audio_file=audio_path)
                    for candidate in ranked_candidates
                ]
                passed_results = [item for item in empirical_results if bool(item.get("passed"))]
                if not passed_results:
                    logger.warning(
                        "Avatar preview empirical precheck warning teacher=%s source=%s results=%s",
                        teacher_id,
                        selected_source.get("source_key"),
                        empirical_results,
                    )
                    if not best_effort_preview_warning:
                        best_effort_preview_warning = (
                            "preview_warning: Selected source is borderline; running full pipeline and relying on strict final validation."
                        )
                    if job_id:
                        Job.objects.filter(id=int(job_id)).update(error_message=best_effort_preview_warning)
                    selected_source_reason = (
                        f"{selected_source_reason}; empirical_lp_precheck_warning={selected_source.get('source_key')}; "
                        "empirical_landmark_jitter=unavailable"
                    )
                else:
                    selected_source_reason = (
                        f"{selected_source_reason}; empirical_lp_precheck_passed={selected_source.get('source_key')}; "
                        f"empirical_landmark_jitter={round(float(passed_results[0].get('landmark_jitter') or 0.0), 6)}"
                    )
                _write_stage_diagnostic(
                    stage="liveportrait_source_precheck",
                    payload={
                        "enabled": True,
                        "candidate_limit": 1,
                        "source_switching_allowed": False,
                        "results": empirical_results,
                        "selected_source_key": selected_source.get("source_key"),
                        "selected_reason": selected_source_reason,
                    },
                )

        if job_id:
            Job.objects.filter(id=int(job_id)).update(status="running", progress=50)
        profile.avatar_last_preview_status = "render_pending"
        profile.avatar_image_status = "processing"
        profile.avatar_preview_error = ""
        profile.avatar_last_preview_job_id = str(job_id or self.request.id or "")
        profile.save(update_fields=["avatar_last_preview_status", "avatar_image_status", "avatar_preview_error", "avatar_last_preview_job_id", "updated_at"])

        info: dict[str, Any] | None = None
        last_exc: Exception | None = None
        attempt_logs: list[dict[str, Any]] = []
        total_attempts = retry_budget
        total_possible_attempts = max(1, total_attempts)
        best_attempt: dict[str, Any] | None = None
        best_raw_score = float("-inf")
        source_abs = str(selected_source.get("source_image_path") or "")
        source_video_for_attempt = str(selected_source.get("source_video_path") or "")
        reference_type = str(selected_source.get("avatar_reference_type") or "image")
        source_key = str(selected_source.get("source_key") or "selected_source")

        readiness_missing_before_render: list[str] = []
        if not source_abs or (not Path(source_abs).exists()):
            readiness_missing_before_render.append("missing_selected_source")
        if not audio_path.exists() or audio_path.stat().st_size <= 0:
            readiness_missing_before_render.append("preview_audio_not_ready")
        if preview_engine == "liveportrait+musetalk":
            if not str(os.environ.get("AVATAR_LIVEPORTRAIT_CMD", "")).strip():
                readiness_missing_before_render.append("liveportrait_engine_unhealthy")
            if not str(os.environ.get("AVATAR_MUSETALK_CMD", "")).strip():
                readiness_missing_before_render.append("musetalk_engine_unhealthy")
        elif not str(os.environ.get("AVATAR_MUSETALK_CMD", "")).strip():
            readiness_missing_before_render.append("musetalk_engine_unhealthy")

        _write_stage_diagnostic(
            stage="readiness_check",
            payload={
                "ready": len(readiness_missing_before_render) == 0,
                "missing": readiness_missing_before_render,
                "selected_source_key": source_key,
                "selected_source_path": source_abs,
                "audio_path": str(audio_path),
                "engine": preview_engine,
            },
        )
        if readiness_missing_before_render:
            raise RuntimeError(
                "setup_not_prepared:readiness_check_failed:"
                + ",".join(sorted(set(readiness_missing_before_render)))
            )

        logger.info(
            "Avatar preview engine activation teacher_id=%s job_id=%s resolved=%s",
            teacher_id,
            job_id,
            preview_engine,
        )

        _stage_log(
            event="stage_started",
            stage="render_pipeline",
            input_path=str(source_abs),
            output_path=str(output_path),
        )
        current_stage = "render_pipeline"
        current_stage_input = str(source_abs)
        current_stage_output = str(output_path)
        current_stage_started_at = time.monotonic()
        render_stage_started_at = time.monotonic()
        for attempt_idx in range(total_attempts):
            variant = preview_variants[attempt_idx]
            if job_id:
                progress = 55 + min(35, int((attempt_idx / float(total_possible_attempts)) * 35))
                Job.objects.filter(id=int(job_id)).update(progress=progress)

            audio_hash = sha256_file(str(audio_path)) if audio_path.exists() else ""
            output_path.unlink(missing_ok=True)
            output_path.with_suffix(output_path.suffix + ".meta.json").unlink(missing_ok=True)
            output_path.with_suffix(output_path.suffix + ".musetalk_debug.json").unlink(missing_ok=True)

            try:
                info = render_avatar_segment_local(
                    AvatarRenderRequest(
                        source_image_path=source_abs,
                        source_image_original_path=source_image_original_abs or source_abs,
                        source_video_path=source_video_for_attempt,
                        avatar_reference_type=reference_type,
                        audio_path=str(audio_path),
                        output_path=str(output_path),
                        motion_preset=profile.avatar_motion_preset or "natural",
                        quality_preset=profile.avatar_quality_preset or "high",
                        lipsync_engine=preview_engine,
                        cache_text_hash=preview_text_hash,
                        enforce_exact_audio_duration=True,
                        musetalk_params=variant,
                        target_frame_count=int(duration_contract["target_frame_count"]),
                        target_duration_seconds=float(duration_contract["target_duration_seconds"]),
                        preview_teacher_id=int(teacher_id),
                        preview_job_id=int(job_id or 0),
                        preview_source_meta=preview_reference_meta,
                    )
                )
                if (time.monotonic() - render_stage_started_at) > stage_render_timeout:
                    raise RuntimeError(f"render_timeout:exceeded_{int(stage_render_timeout)}s")
                motion = info.get("motion_validation") or {}
                quality = motion.get("quality_checks") or {}
                score_breakdown = motion.get("animation_score_breakdown") or {}
                stage_traces = info.get("frame_trace") or {}
                runtime_trace = stage_traces.get("musetalk_runtime") if isinstance(stage_traces, dict) else {}
                raw_validation = runtime_trace.get("raw_validation") if isinstance(runtime_trace, dict) else {}
                attempt_logs.append(
                    {
                        "attempt": len(attempt_logs) + 1,
                        "source_key": source_key,
                        "source_label": selected_source.get("source_label"),
                        "source_preflight_score": selected_source.get("preflight_score"),
                        "source_ranking_score": selected_source.get("ranking_score"),
                        "source_ranking_reason": selected_source.get("ranking_reason"),
                        "engine": preview_engine,
                        "pose_backend": "real_mmpose",
                        "script": preview_script,
                        **variant,
                        "tts_provider": tts_provider,
                        "tts_cache_hit": preview_audio_cache_hit,
                        "tts_duration_seconds": tts_meta.get("duration"),
                        "generated_audio_duration_seconds": round(generated_duration, 4),
                        "contract_audio_duration_seconds": round(contract_duration, 4),
                        "target_frame_count": duration_contract.get("target_frame_count"),
                        "target_duration_seconds": duration_contract.get("target_duration_seconds"),
                        "audio_hash": audio_hash,
                        "audio_duration_seconds": motion.get("audio_duration_seconds"),
                        "video_duration_seconds": motion.get("video_duration_seconds"),
                        "duration_delta_seconds": motion.get("duration_delta_seconds"),
                        "frame_count": motion.get("frame_count"),
                        "raw_motion_score": raw_validation.get("animation_score"),
                        "raw_duration_delta_seconds": raw_validation.get("duration_delta_seconds"),
                        "raw_failure_reason": raw_validation.get("failure_reason") or "",
                        "score_breakdown": score_breakdown,
                        "mouth_openness_change": quality.get("mouth_openness_change"),
                        "eye_blink_change": quality.get("eye_blink_change"),
                        "head_motion_score": quality.get("head_motion_score"),
                        "loop_detected": quality.get("loop_detected"),
                        "face_artifact_detected": quality.get("face_artifact_detected"),
                        "motion_real": motion.get("motion_real"),
                        "animated": motion.get("animated"),
                        "failure_reason": motion.get("failure_reason") or "",
                    }
                )
                break
            except Exception as render_exc:
                err = str(render_exc or "")
                last_exc = render_exc
                debug_path, debug_report = _load_debug_report(err)
                runtime_trace = ((debug_report.get("stage_traces") or {}).get("musetalk_runtime") or {}) if debug_report else {}
                raw_validation = (runtime_trace.get("raw_validation") or {}) if isinstance(runtime_trace, dict) else {}
                score_breakdown = (debug_report.get("metrics") or {}).get("animation_score_breakdown") if debug_report else {}
                raw_score = float(raw_validation.get("animation_score") or (debug_report.get("metrics") or {}).get("animation_score") or 0.0)
                if raw_score > best_raw_score:
                    best_raw_score = raw_score
                    best_attempt = {
                        "source_key": source_key,
                        "source_label": selected_source.get("source_label"),
                        "source_preflight_score": selected_source.get("preflight_score"),
                        "source_ranking_score": selected_source.get("ranking_score"),
                        "source_ranking_reason": selected_source.get("ranking_reason"),
                        "params": dict(variant),
                        "debug_path": debug_path,
                        "raw_motion_score": raw_score,
                        "raw_failure_reason": str(raw_validation.get("failure_reason") or ""),
                    }
                attempt_logs.append(
                    {
                        "attempt": len(attempt_logs) + 1,
                        "source_key": source_key,
                        "source_label": selected_source.get("source_label"),
                        "source_preflight_score": selected_source.get("preflight_score"),
                        "source_ranking_score": selected_source.get("ranking_score"),
                        "source_ranking_reason": selected_source.get("ranking_reason"),
                        "engine": preview_engine,
                        "pose_backend": "real_mmpose",
                        "script": preview_script,
                        **variant,
                        "generated_audio_duration_seconds": round(generated_duration, 4),
                        "tts_cache_hit": preview_audio_cache_hit,
                        "contract_audio_duration_seconds": round(contract_duration, 4),
                        "target_frame_count": duration_contract.get("target_frame_count"),
                        "target_duration_seconds": duration_contract.get("target_duration_seconds"),
                        "audio_hash": audio_hash,
                        "raw_motion_score": raw_score,
                        "raw_duration_delta_seconds": raw_validation.get("duration_delta_seconds"),
                        "raw_failure_reason": raw_validation.get("failure_reason") or "",
                        "score_breakdown": score_breakdown or {},
                        "debug_path": debug_path,
                        "failure_reason": err,
                    }
                )
                err_l = err.lower()
                is_validation = (
                    "strict acceptance gate" in err_l
                    or "validation failed" in err_l
                    or "shorter than preview audio" in err_l
                    or "duration" in err_l
                    or "duration contract" in err_l
                )
                if not is_validation:
                    raise
                if attempt_idx < (total_attempts - 1):
                    logger.warning(
                        "Avatar preview validation retry teacher=%s source=%s attempt=%s/%s reason=%s",
                        teacher_id,
                        source_key,
                        attempt_idx + 1,
                        total_attempts,
                        err,
                    )
                    continue
                logger.warning(
                    "Avatar preview selected source exhausted teacher=%s source=%s reason=%s fallback_switching=%s",
                    teacher_id,
                    source_key,
                    err,
                    False,
                )

        allow_unstable_preview_render = str(os.environ.get("AVATAR_PREVIEW_ALLOW_UNSTABLE_OUTPUT", "1")).strip().lower() in {
            "1",
            "true",
            "yes",
            "on",
        }
        render_stage_status = "success"
        if info is None:
            render_stage_status = "strict_rejected_pending_unstable_fallback" if allow_unstable_preview_render else "failed"

        _stage_log(
            event="stage_finished",
            stage="render_pipeline",
            input_path=str(source_abs),
            output_path=str(output_path),
            elapsed_seconds=(time.monotonic() - render_stage_started_at),
            details=render_stage_status,
        )
        _write_stage_diagnostic(
            stage="render_pipeline",
            payload={
                "engine": preview_engine,
                "source_key": source_key,
                "output_path": str(output_path),
                "status": render_stage_status,
                "attempt_logs": attempt_logs,
            },
        )
        current_stage = ""

        if info is None:
            if best_attempt:
                raise RuntimeError(
                    "Avatar preview failed with selected source and controlled MuseTalk parameter sweep. "
                    f"best_source={best_attempt.get('source_key') or ''} "
                    f"source_ranking_reason={best_attempt.get('source_ranking_reason') or ''} "
                    f"source_ranking_score={best_attempt.get('source_ranking_score')} "
                    f"best_debug_path={best_attempt.get('debug_path') or ''} "
                    f"best_params={best_attempt.get('params') or {}} "
