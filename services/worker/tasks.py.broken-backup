        source_audio_rel_path = _safe_rel_path(storage_root, str(source_tts_path)) if source_tts_path.exists() else ""
        contract_audio_rel_path = _safe_rel_path(storage_root, str(audio_path)) if audio_path.exists() else ""

        return {
            "teacher_id": int(teacher_id),
            "job_id": int(job_id) if job_id else None,
            "preview_rel_path": rel_preview,
            "preview_status": preview_status_value,
            "engine_used": info.get("engine_used"),
            "unstable_output_accepted": unstable_output_accepted,
            "failure_category": unstable_failure_category,
            "warning": pipeline_preview_warning,
            "fallback_chain_used": info.get("fallback_chain_used", []),
            "audio_hash": audio_hash,
            "video_hash": video_hash,
            "preview_audio_source_rel_path": source_audio_rel_path,
            "preview_audio_contract_rel_path": contract_audio_rel_path,
            "preview_audio_contract_format": "wav",
            "motion_validation": info.get("motion_validation", {}),
            "attempts": attempt_logs,
            "preview_audio_cache_hit": preview_audio_cache_hit,
            "trim_info": info.get("trim_info", {}),
            "duration_contract": duration_contract,
            "animation_score_breakdown": animation_score_breakdown,
            "preview_reference": preview_reference_meta,
            "preview_sources_considered": [
                {
                    "source_key": item.get("source_key"),
                    "source_label": item.get("source_label"),
                    "preflight_score": item.get("preflight_score"),
                    "face_centering_score": item.get("face_centering_score"),
                    "forehead_headroom_score": item.get("forehead_headroom_score"),
                    "mouth_position_score": item.get("mouth_position_score"),
                    "history_quality_rank": item.get("history_quality_rank"),
                    "history_lip_movement_score": item.get("history_lip_movement_score"),
                    "history_mouth_openness_change": item.get("history_mouth_openness_change"),
                    "ranking_reason": item.get("ranking_reason"),
                    "ranking_score": item.get("ranking_score"),
                }
                for item in preview_source_candidates
            ],
            "selected_preview_source": {
                "source_key": selected_source.get("source_key"),
                "source_label": selected_source.get("source_label"),
                "selected_reason": selected_source_reason,
                "ranking_reason": selected_source.get("ranking_reason"),
                "ranking_score": selected_source.get("ranking_score"),
                "preflight_score": selected_source.get("preflight_score"),
                "face_centering_score": selected_source.get("face_centering_score"),
                "forehead_headroom_score": selected_source.get("forehead_headroom_score"),
                "mouth_position_score": selected_source.get("mouth_position_score"),
                "history_lip_movement_score": selected_source.get("history_lip_movement_score"),
                "history_mouth_openness_change": selected_source.get("history_mouth_openness_change"),
            },
            "selected_vs_runner_up": {
                "winner": {
                    "source_key": selected_source.get("source_key"),
                    "ranking_score": selected_source.get("ranking_score"),
                    "history_lip_movement_score": selected_source.get("history_lip_movement_score"),
                    "history_mouth_openness_change": selected_source.get("history_mouth_openness_change"),
                    "mouth_position_score": selected_source.get("mouth_position_score"),
                },
                "runner_up": {
                    "source_key": (runner_up or {}).get("source_key"),
                    "ranking_score": (runner_up or {}).get("ranking_score"),
                    "history_lip_movement_score": (runner_up or {}).get("history_lip_movement_score"),
                    "history_mouth_openness_change": (runner_up or {}).get("history_mouth_openness_change"),
                    "mouth_position_score": (runner_up or {}).get("mouth_position_score"),
                },
            },
        }
    except SoftTimeLimitExceeded as exc:
        if current_stage:
            _stage_log(
                event="stage_finished",
                stage=current_stage,
                input_path=current_stage_input,
                output_path=current_stage_output,
                elapsed_seconds=(time.monotonic() - current_stage_started_at if current_stage_started_at else 0.0),
                details="failed:render_timeout",
            )
        err_msg = f"render_timeout:task_soft_time_limit_{_PREVIEW_TASK_SOFT_TIMEOUT_SECONDS}s"
        logger.exception("Avatar preview render soft-timeout teacher=%s job=%s", teacher_id, job_id)
        profile.avatar_last_preview_status = "render_failed"
        profile.avatar_image_status = "failed"
        profile.avatar_preview_error = "Preview render exceeded stage budget and was stopped."
        profile.avatar_last_preview_job_id = str(job_id or self.request.id or "")
        profile.avatar_preview_video = ""
        profile.avatar_last_preview_path = ""
        profile.save(update_fields=["avatar_last_preview_status", "avatar_image_status", "avatar_last_preview_job_id", "avatar_preview_video", "avatar_last_preview_path", "avatar_preview_error", "updated_at"])
        if job_id:
            Job.objects.filter(id=int(job_id)).update(status="failed", progress=100, error_message=err_msg)
        raise
    except Exception as exc:
        if current_stage:
            _stage_log(
                event="stage_finished",
                stage=current_stage,
                input_path=current_stage_input,
                output_path=current_stage_output,
                elapsed_seconds=(time.monotonic() - current_stage_started_at if current_stage_started_at else 0.0),
                details=f"failed:{str(exc)[:280]}",
            )
        err_msg = str(exc or "")
        err_l = err_msg.lower()
        bad_tts_failure = any(
            token in err_l
            for token in [
                "tts_audio_invalid",
                "tts_service_fallback_audio",
                "tts_timeout",
                "tts_ready_timeout",
                "tts_service_failed",
                "preview_audio_missing",
            ]
        )
        setup_failure = any(
            token in err_l
            for token in [
                "setup_not_prepared",
                "teacher avatar is not prepared",
                "voice profile is missing",
            ]
        )
        preflight_failure = any(
            token in err_l
            for token in [
                "avatar preview preflight rejected all sources",
                "preflight_rejected",
            ]
        )
        liveportrait_failure = any(
            token in err_l
            for token in [
                "liveportrait stage output rejected",
                "liveportrait_precheck_failed",
                "liveportrait_landmark_instability",
                "liveportrait_face_artifact",
                "liveportrait_stage_failed",
            ]
        )
        musetalk_failure = any(
            token in err_l
            for token in [
                "musetalk stage failed",
                "musetalk_output_rejected",
                "musetalk_timeout",
            ]
        )
        timeout_or_stall_failure = any(
            token in err_l
            for token in [
                "render_timeout",
                "preflight_timeout",
                "liveportrait_timeout",
                "musetalk_timeout",
                "restoration_timeout",
                "stage_stalled",
            ]
        )
        validation_failure = any(
            token in err_l
            for token in [
                "validation failed",
                "rejected by strict acceptance gate",
                "motion_real",
                "low_lip_motion",
                "low_eye_motion",
                "loop_like_motion",
                "face_roi_artifact",
                "low_mouth_openness_change",
                "whole_frame_drift",
                "glitch_artifact",
                "duration contract",
            ]
        )
        transient_failure = any(
            token in err_l
            for token in [
                "timeout",
                "temporarily unavailable",
                "connection reset",
                "connection aborted",
                "resource temporarily unavailable",
                "network",
                "econn",
            ]
        )

        if transient_failure and not validation_failure and not bad_tts_failure and not timeout_or_stall_failure and int(getattr(self.request, "retries", 0)) < 2:
            logger.warning(
                "Avatar preview transient failure teacher=%s job=%s retry=%s error=%s",
                teacher_id,
                job_id,
                int(getattr(self.request, "retries", 0)),
                err_msg,
            )
            if job_id:
                Job.objects.filter(id=int(job_id)).update(status="running", progress=25, error_message="")
            profile.avatar_last_preview_status = "render_pending"
            profile.avatar_image_status = "processing"
            profile.avatar_preview_error = ""
            profile.avatar_last_preview_job_id = str(job_id or self.request.id or "")
            profile.save(update_fields=["avatar_last_preview_status", "avatar_image_status", "avatar_last_preview_job_id", "avatar_preview_error", "updated_at"])
            raise self.retry(exc=exc, countdown=10)

        if setup_failure:
            failure_category = "setup_not_prepared"
        elif bad_tts_failure:
            failure_category = "tts_failed"
        elif preflight_failure:
            failure_category = "preflight_failed"
        elif liveportrait_failure:
            failure_category = "liveportrait_failed"
        elif musetalk_failure:
            failure_category = "musetalk_failed"
        elif validation_failure:
            failure_category = "validation_failed"
        elif timeout_or_stall_failure:
            failure_category = "render_timeout_or_stall"
        else:
            failure_category = "render_failed"

        allow_unstable_preview = str(os.environ.get("AVATAR_PREVIEW_ALLOW_UNSTABLE_OUTPUT", "1")).strip().lower() in {
            "1",
            "true",
            "yes",
            "on",
        }
        preview_debug_accept_unstable = str(os.environ.get("AVATAR_PREVIEW_DEBUG_ACCEPT_UNSTABLE", "0")).strip().lower() in {
            "1",
            "true",
            "yes",
            "on",
        }
        non_broken_input_failure = not setup_failure and not bad_tts_failure and not preflight_failure
        keep_playable_output = bool(non_broken_input_failure and allow_unstable_preview)
        if keep_playable_output:
            smoke_candidates = sorted(
                output_path.parent.glob(f"{output_path.name}.liveportrait.*.smoke.mp4"),
                key=lambda p: float(p.stat().st_mtime) if p.exists() else 0.0,
                reverse=True,
            )
            candidate_outputs = [
                output_path,
                output_path.with_suffix(output_path.suffix + ".musetalk.mp4"),
                output_path.with_suffix(output_path.suffix + ".liveportrait.mp4"),
            ]
            candidate_outputs.extend(smoke_candidates)
            chosen_output = next(
                (
                    path
                    for path in candidate_outputs
                    if Path(path).exists()
                    and Path(path).is_file()
                    and Path(path).stat().st_size > 0
                    and float(Path(path).stat().st_mtime) >= (preview_job_started_epoch - 2.0)
                ),
                None,
            )
            if chosen_output is not None:
                rel_preview = _safe_rel_path(storage_root, str(chosen_output))
                chosen_output_text = str(chosen_output)
                if chosen_output_text.endswith(".musetalk.mp4") or chosen_output_text == str(output_path):
                    chosen_engine_used = preview_engine
                else:
                    chosen_engine_used = "liveportrait"
                warning_category = failure_category or "warning_only"
                preview_status_value = "warning"
                warning_message = (
                    "preview_warning: Playable preview output preserved for continuity; "
                    f"failure_category={warning_category}; strict_error={str(err_msg)[:220]}"
                )
                logger.warning(
                    "Avatar preview playable stage preserved teacher=%s job=%s debug_mode=%s failure_category=%s output=%s",
                    teacher_id,
                    job_id,
                    bool(preview_debug_accept_unstable),
                    warning_category,
                    str(chosen_output),
                )
                profile.avatar_last_preview_status = preview_status_value
                profile.avatar_image_status = "ready"
                profile.avatar_preview_error = warning_message
                profile.avatar_last_preview_job_id = str(job_id or self.request.id or "")
                profile.avatar_preview_video = rel_preview
                profile.avatar_last_preview_path = rel_preview
                profile.save(
                    update_fields=[
                        "avatar_last_preview_status",
                        "avatar_image_status",
                        "avatar_preview_error",
                        "avatar_last_preview_job_id",
                        "avatar_preview_video",
                        "avatar_last_preview_path",
                        "updated_at",
                    ]
                )
                if job_id:
                    Job.objects.filter(id=int(job_id)).update(
                        status="done",
                        progress=100,
                        result_url=rel_preview,
                        error_message=warning_message,
                    )

                return {
                    "teacher_id": int(teacher_id),
                    "job_id": int(job_id) if job_id else None,
                    "preview_rel_path": rel_preview,
                    "preview_status": preview_status_value,
                    "engine_used": chosen_engine_used,
                    "unstable_output_accepted": True,
                    "failure_category": warning_category,
                    "warning": warning_message,
                }
            logger.warning(
                "Avatar preview fallback skipped stale outputs teacher=%s job=%s job_started_epoch=%s candidates=%s",
                teacher_id,
                job_id,
                preview_job_started_epoch,
                [str(path) for path in candidate_outputs],
            )

        logger.exception(
            "Avatar preview render failed teacher=%s job=%s failure_category=%s",
            teacher_id,
            job_id,
            failure_category,
        )
        friendly_error = _friendly_preview_error(err_msg)
        if setup_failure:
            profile.avatar_last_preview_status = "setup_failed"
        elif bad_tts_failure:
            profile.avatar_last_preview_status = "tts_failed"
        elif preflight_failure:
            profile.avatar_last_preview_status = "preflight_failed"
        elif liveportrait_failure:
            profile.avatar_last_preview_status = "liveportrait_failed"
        elif musetalk_failure:
            profile.avatar_last_preview_status = "musetalk_failed"
        elif validation_failure:
            profile.avatar_last_preview_status = "validation_failed"
        else:
            profile.avatar_last_preview_status = "render_failed"
        profile.avatar_image_status = "failed"
        profile.avatar_preview_error = friendly_error
        profile.avatar_last_preview_job_id = str(job_id or self.request.id or "")
        profile.avatar_preview_video = ""
        profile.avatar_last_preview_path = ""
        profile.save(update_fields=["avatar_last_preview_status", "avatar_image_status", "avatar_last_preview_job_id", "avatar_preview_video", "avatar_last_preview_path", "avatar_preview_error", "updated_at"])
        if job_id:
            Job.objects.filter(id=int(job_id)).update(status="failed", progress=100, error_message=friendly_error)
        raise


