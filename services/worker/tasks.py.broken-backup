        if unstable_output_accepted:
            logger.warning(
                "Avatar preview best-effort continuity accepted teacher=%s job=%s source_key=%s failure_category=%s output=%s",
                teacher_id,
                job_id,
                source_key,
                unstable_failure_category or "liveportrait_warning",
                rel_preview,
            )
            # Successful preview completion should not be returned as a failed category.
            unstable_failure_category = ""
        preview_status_value = "warning" if pipeline_preview_warning else "render_ready"
        profile.avatar_preview_video = rel_preview
        profile.avatar_last_preview_path = rel_preview
        profile.avatar_last_preview_status = preview_status_value
        profile.avatar_image_status = "ready"
        profile.avatar_preview_error = pipeline_preview_warning if pipeline_preview_warning else ""
        profile.avatar_last_preview_job_id = str(job_id or self.request.id or "")
        profile.save(
